{
  "permissions": {
    "allow": [
      "Bash(yarn --version)",
      "Bash(yarn install *)",
      "Bash(yarn build *)",
      "Bash(npm install *)",
      "Bash(git add *)",
      "Bash(grep -iE \"\\\\.env\\(\\\\.local\\)?$|\\\\.env\\\\.\")",
      "Bash(git commit *)",
      "Bash(git remote *)",
      "Bash(git branch *)",
      "Bash(git push *)",
      "Bash(git credential *)",
      "Bash(echo \"exit=$?\")",
      "Bash(git config *)",
      "Bash(env)",
      "Bash(cmdkey /list)",
      "PowerShell(cmdkey /list)",
      "PowerShell(Select-String -Pattern 'github|git:' -CaseSensitive:$false)",
      "PowerShell(git credential-manager configure 2>&1)",
      "PowerShell(git credential-manager diagnose 2>&1)",
      "PowerShell(Select-String -Pattern 'store|credential|account|github' -CaseSensitive:$false)",
      "PowerShell($p = \"$env:LOCALAPPDATA\\\\GitCredentialManager\"; if \\(Test-Path $p\\) { Get-ChildItem $p -Recurse -File | Select-Object -First 20 FullName, Length } else { Write-Output \"GCM store dir not present: $p\" }; Write-Output \"---\"; git config --global credential.credentialStore)",
      "Bash(vercel.cmd --version)",
      "Bash(vercel.cmd whoami *)",
      "Bash(grep -vE \"^$|Update|Changelog|Run|───\")",
      "Bash(vercel.cmd teams *)",
      "Bash(vercel.cmd link *)",
      "Bash(vercel.cmd --prod --yes)"
    ]
  }
}
