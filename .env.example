# Supabase — required for auth + data
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Model API keys for agent runtime. Chutes is primary (Kimi K2.6-TEE),
# OpenRouter is the fallback. Anthropic is NOT used by agent code — that
# auth is reserved for human-driven dev tools (Claude Code, Cowork).
CHUTES_API_KEY=
OPENROUTER_API_KEY=

# Orchestrator webhook (production — separate service)
ORCHESTRATOR_WEBHOOK_URL=
ORCHESTRATOR_WEBHOOK_SECRET=

# Onboarding Engine server (Phase C) — VPS HTTP wrapper for engine.mjs.
# Generate token: openssl rand -hex 32. Same value goes in pm2 env on VPS.
ONBOARDING_SERVER_URL=http://your-vps:7711
ONBOARDING_SERVER_TOKEN=
