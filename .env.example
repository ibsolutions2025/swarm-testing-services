# Supabase — required for auth + data
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — model API keys if orchestrator runs in-process
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Orchestrator webhook (production — separate service)
ORCHESTRATOR_WEBHOOK_URL=
ORCHESTRATOR_WEBHOOK_SECRET=

# Onboarding Engine server (Phase C) — VPS HTTP wrapper for engine.mjs.
# Generate token: openssl rand -hex 32. Same value goes in pm2 env on VPS.
ONBOARDING_SERVER_URL=http://your-vps:7711
ONBOARDING_SERVER_TOKEN=
