# Supabase — required for auth + data
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — model API keys if orchestrator runs in-process
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Orchestrator webhook (production — separate service)
ORCHESTRATOR_WEBHOOK_URL=
ORCHESTRATOR_WEBHOOK_SECRET=
